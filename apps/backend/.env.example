# Variáveis de ambiente do backend — Manga Larga
# Copie este arquivo para .env e preencha com os valores reais.

PORT=3000

# JWT — Segredo usado para assinar os tokens. Use um valor longo e aleatório em produção.
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Tempo de expiração do token JWT (ex: 60m, 1h, 7d)
JWT_EXPIRES_IN=60m

# Usuário administrador criado automaticamente via seed na primeira execução
ADMIN_EMAIL=admin@mangalarga.com
ADMIN_PASSWORD=Admin@1234
ADMIN_NOME=Administrador
